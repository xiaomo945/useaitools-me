generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                 String              @id @default(cuid())
  name               String?
  email              String?             @unique
  emailVerified      DateTime?
  image              String?
  role               String              @default("user")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  accounts           Account[]
  bookmarks          Bookmark[]
  collections        Collection[]
  discussions        Discussion[]
  discussionComments DiscussionComment[]
  emailSubscription  EmailSubscription?
  notifications      Notification[]
  reviews            Review[]
  sessions           Session[]
  submissions        Submission[]
  blogPosts          BlogPost[]
  memberships        Membership[]
  sponsoredOrders    SponsoredOrder[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Tool {
  id              String       @id @default(cuid())
  name            String
  slug            String       @unique
  description     String
  longDescription String?
  category        String
  subcategory     String?
  url             String
  affiliateUrl    String?
  iconUrl         String?
  screenshotUrls  String?
  videoUrl        String?
  pricing         String       @default("free")
  priceMonthly    Float?
  priceYearly     Float?
  rating          Float        @default(0)
  reviewCount     Int          @default(0)
  viewCount       Int          @default(0)
  clickCount      Int          @default(0)
  monthlyVisits   Int?         // 外部流量数据：月访问量
  trafficRank     Int?         // 外部流量数据：全球排名
  lastTrafficUpdate DateTime?  // 流量数据最后更新时间
  lastVerified    DateTime?    // 工具信息最后验证时间
  isActive        Boolean      @default(true)
  isFeatured      Boolean      @default(false)
  isStaffPick     Boolean      @default(false)
  tags            String?
  features        String?
  pros            String?
  cons            String?
  useCases        String?   // JSON array: [{title, detail}]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  bookmarks       Bookmark[]
  discussions     Discussion[]
  reviews         Review[]
  updates         ToolUpdate[]
  toolReviews     ToolReview[]

  @@index([category])
  @@index([slug])
  @@index([rating])
  @@index([isActive])
  @@index([isFeatured])
  @@index([clickCount])
  @@index([createdAt])
  @@index([pricing])
  @@index([monthlyVisits])
  @@index([trafficRank])
}

model Category {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  description String?
  icon        String?
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")

  @@index([slug])
  @@index([parentId])
  @@index([sortOrder])
}

model BlogCategory {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  posts       BlogPost[]

  @@index([slug])
}

model BlogPost {
  id              String       @id @default(cuid())
  title           String
  slug            String       @unique
  excerpt         String
  content         String
  metaTitle       String?
  metaDescription String?
  coverImage      String?
  coverImageAlt   String?
  tags            String?
  relatedToolIds  String?
  viewCount       Int          @default(0)
  isPublished     Boolean      @default(false)
  isFeatured      Boolean      @default(false)
  publishedAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  categoryId      String
  category        BlogCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  authorId        String
  author          User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  toolReview      ToolReview?
  templateId      String?
  template        BlogPostTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([slug])
  @@index([isPublished])
  @@index([publishedAt])
  @@index([categoryId])
  @@index([isFeatured])
  @@index([viewCount])
  @@index([createdAt])
}

model BlogPostTemplate {
  id          String   @id @default(cuid())
  name        String
  type        String   // review, comparison, tutorial, news
  description String?
  structure   String   // JSON array of sections
  guidelines  String?  // JSON object with quality standards
  isActive    Boolean  @default(true)
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  posts       BlogPost[]
  
  @@index([type])
  @@index([isActive])
  @@index([isDefault])
}

model ToolReviewTemplate {
  id               String   @id @default(cuid())
  name             String
  description      String?
  sections         String   // JSON array
  ratingDimensions String?  // JSON array
  isActive         Boolean  @default(true)
  isDefault        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  reviews          ToolReview[]
  
  @@index([isActive])
  @@index([isDefault])
}

model ToolReview {
  id              String   @id @default(cuid())
  overview        String
  features        String?  // JSON array
  pros            String?  // JSON array
  cons            String?  // JSON array
  ratings         String?  // JSON object
  bestFor         String?  // JSON array
  overallRating   Float    @default(0)
  recommendation  String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  blogPostId      String   @unique
  blogPost        BlogPost @relation(fields: [blogPostId], references: [id], onDelete: Cascade)
  
  toolId          String
  tool            Tool     @relation(fields: [toolId], references: [id], onDelete: Cascade)
  
  templateId      String?
  template        ToolReviewTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  
  @@index([toolId])
  @@index([blogPostId])
  @@index([overallRating])
}

model Review {
  id         String   @id @default(cuid())
  rating     Int
  title      String?
  content    String
  pros       String?
  cons       String?
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  userId     String
  toolId     String
  tool       Tool     @relation(fields: [toolId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, toolId])
  @@index([toolId])
  @@index([userId])
}

model Bookmark {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String
  toolId    String
  tool      Tool     @relation(fields: [toolId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, toolId])
  @@index([userId])
  @@index([toolId])
}

model Submission {
  id          String    @id @default(cuid())
  name        String
  url         String
  description String
  category    String
  email       String
  status      String    @default("pending")
  reviewedBy  String?
  reviewedAt  DateTime?
  reviewNote  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([userId])
}

model Collection {
  id          String   @id @default(cuid())
  name        String
  description String?
  isPublic    Boolean  @default(false)
  slug        String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([slug])
}

model Discussion {
  id           String              @id @default(cuid())
  title        String
  content      String
  category     String              @default("general")
  viewCount    Int                 @default(0)
  commentCount Int                 @default(0)
  likeCount    Int                 @default(0)
  isPinned     Boolean             @default(false)
  isLocked     Boolean             @default(false)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  userId       String
  toolId       String?
  tool         Tool?               @relation(fields: [toolId], references: [id], onDelete: Cascade)
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments     DiscussionComment[]

  @@index([userId])
  @@index([toolId])
  @@index([category])
  @@index([isPinned])
}

model DiscussionComment {
  id           String     @id @default(cuid())
  content      String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  userId       String
  discussionId String
  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([discussionId])
  @@index([userId])
}

model ToolUpdate {
  id        String   @id @default(cuid())
  toolId    String
  title     String
  content   String
  type      String   @default("feature")
  createdAt DateTime @default(now())
  tool      Tool     @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@index([toolId])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  content   String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model EmailSubscription {
  id              String     @id @default(cuid())
  userId          String     @unique
  categories      String?
  frequency       String     @default("weekly")
  emailFormat     String     @default("html")
  isActive        Boolean    @default(true)
  lastEmailSentAt DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  logs            EmailLog[]
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
}

model EmailLog {
  id             String            @id @default(cuid())
  subscriptionId String
  subject        String
  content        String
  toolIds        String?
  status         String            @default("sent")
  sentAt         DateTime          @default(now())
  deliveredAt    DateTime?
  openedAt       DateTime?
  clickedAt      DateTime?
  subscription   EmailSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([sentAt])
  @@index([status])
}

model SiteSubscription {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  source    String   @default("website")
  status    String   @default("active")
  interests String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@index([source])
}

model ContentReport {
  id          String   @id @default(cuid())
  reportType  String   // weekly, monthly, seo, tools, content
  periodStart DateTime
  periodEnd   DateTime
  data        String   // JSON object
  summary     String?  // Human-readable summary
  generatedBy String   // system or user email
  createdAt   DateTime @default(now())

  @@index([reportType])
  @@index([periodStart])
  @@index([createdAt])
}

model AffiliateLink {
  id              String   @id @default(cuid())
  toolId          String?
  toolName        String
  linkType        String
  affiliateUrl    String
  originalUrl     String?
  network         String?
  status          String   @default("active")
  clickCount      Int      @default(0)
  conversionCount Int      @default(0)
  revenue         Float    @default(0)
  startDate       DateTime?
  endDate         DateTime?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([toolId])
  @@index([status])
  @@index([network])
}

model UserInteraction {
  id            String   @id @default(cuid())
  sessionId     String
  actionType    String   // view, bookmark, compare, click, search
  toolId        String?
  toolName      String?
  category      String?
  searchQuery   String?
  metadata      String?  // JSON 元数据
  createdAt     DateTime @default(now())
  @@index([sessionId])
  @@index([actionType])
  @@index([toolId])
  @@index([createdAt])
  @@index([category])
}

model SponsoredSlot {
  id            String   @id @default(cuid())
  slotName      String
  title         String
  description   String?
  url           String
  imageUrl      String?
  price         Float    @default(0)
  currency      String   @default("USD")
  advertiser    String?
  status        String   @default("active")
  startDate     DateTime?
  endDate       DateTime?
  clickCount    Int      @default(0)
  viewCount     Int      @default(0)
  priority      Int      @default(0)
  category      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([slotName, status])
  @@index([status])
}

model Keyword {
  id               String   @id @default(cuid())
  keyword          String   @unique
  position         Int
  previousPosition Int
  change           Int
  url              String
  searchVolume     Int
  difficulty       Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([keyword])
  @@index([position])
  @@index([change])
}

model Competitor {
  id            String   @id @default(cuid())
  name          String
  domain        String   @unique
  trafficRank   Int
  monthlyVisits Int
  topKeywords   String   // JSON array
  strengths     String   // JSON array
  weaknesses    String   // JSON array
  lastUpdated   DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([domain])
  @@index([trafficRank])
}

model Report {
  id          String   @id @default(cuid())
  type        String   // weekly, monthly
  title       String
  period      String   // JSON: {start, end}
  metrics     String   // JSON object
  topPages    String   // JSON array
  topKeywords String   // JSON array
  insights    String   // JSON array
  generatedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([generatedAt])
}

model Advertisement {
  id            String   @id @default(cuid())
  name          String   // 广告位名称（内部标识）
  title         String   // 广告标题
  description   String?  // 广告描述
  imageUrl      String?  // 广告图片
  targetUrl     String   // 点击跳转链接
  position      String   // 广告位置：header, sidebar, footer, inline
  adType        String   // 广告类型：banner, native, sponsored
  status        String   @default("active") // active, paused, expired
  startDate     DateTime?
  endDate       DateTime?
  price         Float    @default(0) // 广告价格
  currency      String   @default("USD")
  advertiser    String?  // 广告主名称
  clickCount    Int      @default(0)
  viewCount     Int      @default(0)
  priority      Int      @default(0) // 优先级，数字越大越优先
  targetCategory String? // 目标分类（可选）
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([position, status])
  @@index([status])
  @@index([priority])
}

model MembershipPlan {
  id            String   @id @default(cuid())
  name          String   // 套餐名称：basic, pro, enterprise
  displayName   String   // 显示名称
  description   String?  // 套餐描述
  price         Float    // 价格
  currency      String   @default("USD")
  interval      String   @default("monthly") // monthly, yearly
  features      String   // JSON array of features
  isPopular     Boolean  @default(false) // 是否推荐
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  memberships   Membership[]

  @@index([name])
  @@index([isActive])
}

model Membership {
  id            String   @id @default(cuid())
  userId        String
  planId        String
  status        String   @default("active") // active, cancelled, expired
  startDate     DateTime @default(now())
  endDate       DateTime?
  cancelledAt   DateTime?
  paymentMethod String?  // stripe, paypal, etc.
  transactionId String?  // 支付交易 ID
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan          MembershipPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([userId, planId])
  @@index([userId])
  @@index([status])
  @@index([endDate])
}

// 赞助位套餐
model SponsoredPackage {
  id            String   @id @default(cuid())
  name          String   // 套餐名称：basic, pro, premium
  displayName   String   // 显示名称
  description   String?  // 套餐描述
  price         Float    // 价格
  currency      String   @default("USD")
  duration      Int      @default(30) // 赞助时长（天）
  position      String   // 广告位置：header, sidebar, footer, inline
  features      String   // JSON array of features
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  orders        SponsoredOrder[]

  @@index([name])
  @@index([position])
  @@index([isActive])
}

// 赞助订单
model SponsoredOrder {
  id            String   @id @default(cuid())
  userId        String
  packageId     String
  status        String   @default("pending") // pending, paid, active, expired, cancelled
  title         String   // 赞助标题
  description   String?  // 赞助描述
  targetUrl     String   // 目标链接
  imageUrl      String?  // 图片链接
  startDate     DateTime? // 开始日期
  endDate       DateTime? // 结束日期
  amount        Float    // 支付金额
  paymentMethod String?  // 支付方式：stripe, paypal, demo
  transactionId String?  // 交易 ID
  clickCount    Int      @default(0)
  viewCount     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  package       SponsoredPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([packageId])
  @@index([status])
  @@index([endDate])
}

// Core Web Vitals metrics collected from the client (WebVitals.tsx)
model WebVital {
  id        String   @id @default(cuid())
  metric    String   // LCP | FID | INP | CLS | TTFB | FCP
  value     Float    // metric value (ms for timing metrics, unitless for CLS)
  rating    String   // good | needs-improvement | poor
  url       String   // page URL where the metric was captured
  sessionId String?  // optional session identifier
  userAgent String?
  createdAt DateTime @default(now())

  @@index([metric])
  @@index([rating])
  @@index([createdAt])
  @@index([url])
}

