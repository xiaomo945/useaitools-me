# =============================================================================
# UseAITools.me 环境变量示例
# 复制为 .env.local 并填入真实值
# =============================================================================

# -----------------------------------------------------------------------------
# 站点配置
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://useaitools.me

# -----------------------------------------------------------------------------
# 联盟链接（Affiliate Links）
# 命名规范：AFFILIATE_{TOOL_NAME}，工具名大写、空格替换为下划线
# 未配置时回退到 data/tools.json 中的 affiliate_link 字段
# -----------------------------------------------------------------------------

# Writing 类
AFFILIATE_RYTR=
AFFILIATE_GRAMMARLY=
AFFILIATE_JASPER=
AFFILIATE_COPYAI=
AFFILIATE_QUILLBOT=

# Video 类
AFFILIATE_VEED=
AFFILIATE_PICTORY=
AFFILIATE_SYNTHESIA=
AFFILIATE_DESCRIPT=

# Audio 类
AFFILIATE_MURF=
AFFILIATE_ELEVENLABS=

# Productivity 类
AFFILIATE_NOTION=

# -----------------------------------------------------------------------------
# 数据库
# -----------------------------------------------------------------------------
DATABASE_URL="file:./dev.db"

# -----------------------------------------------------------------------------
# 认证（NextAuth）
# -----------------------------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# -----------------------------------------------------------------------------
# 邮件服务（Resend）
# -----------------------------------------------------------------------------
RESEND_API_KEY=

# -----------------------------------------------------------------------------
# 分析与监控
# -----------------------------------------------------------------------------
# Plausible Analytics（可选）
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Microsoft Clarity（可选）
NEXT_PUBLIC_CLARITY_ID=

# -----------------------------------------------------------------------------
# AI 服务（可选）
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
